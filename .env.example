# FreightVoice environment — copy to .env (which is gitignored).
#
# IMPORTANT: the core demo needs NONE of these. `make demo` runs with zero config.
# Everything below is optional hardening / production wiring.

# --- TMS backend (the adapter seam) --------------------------------------- #
# fake (default, runs the demo) | samsara | motive
FREIGHTVOICE_TMS=fake
FAKETMS_URL=http://127.0.0.1:5001

# --- Fake TMS storage backend (the storage seam) -------------------------- #
# sqlite (default, zero-config) | insforge (managed Postgres + auto REST API)
FAKETMS_STORAGE=sqlite
# Only when FAKETMS_STORAGE=insforge. Self-hosted Docker default shown; for cloud
# use https://<your-app>.insforge.app. Tables loads/pods/discrepancies must exist.
# FAKETMS_INSFORGE_URL=http://localhost:7130
# FAKETMS_INSFORGE_TOKEN=your-insforge-bearer-token

# --- Discrepancy tuning --------------------------------------------------- #
FREIGHTVOICE_WEIGHT_TOLERANCE_PCT=5

# --- Opt-in Vapi webhook auth (off unless a secret is set) ---------------- #
# VAPI_WEBHOOK_SECRET=change-me
# VAPI_AUTH_MODE=token            # token | hmac
# VAPI_SIGNATURE_HEADER=          # blank => X-Vapi-Secret (token) / X-Vapi-Signature (hmac)

# --- Real TMS credentials (only when FREIGHTVOICE_TMS != fake) ------------- #
# SAMSARA_API_TOKEN=
# MOTIVE_API_KEY=
# RTS_API_KEY=

# =========================================================================== #
# The NEBIUS API KEY does NOT belong here.
# Vapi calls Nebius directly as its custom-LLM provider, so the key goes in the
# Vapi dashboard -> Provider Keys (BYOK). The middleware never makes a Nebius
# call and must not hold the key.
#
# The ONLY exception is the offline fine-tuning script in docs/VAPI_SETUP.md §4,
# which you'd run by hand with NEBIUS_API_KEY exported in your shell — not via
# this file, and never committed.
# =========================================================================== #
